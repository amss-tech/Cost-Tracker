# =============================================================================
# Tusco ES — Self-Hosted Backend Environment Variables
#
# Copy to .env and fill in every value before running docker compose up.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain
# Your subdomain that points to this droplet (A record in DNS)
# -----------------------------------------------------------------------------
DOMAIN=api.tusco-es.com

# -----------------------------------------------------------------------------
# Postgres
# POSTGRES_PASSWORD: generate with: openssl rand -base64 24
# -----------------------------------------------------------------------------
POSTGRES_DB=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# -----------------------------------------------------------------------------
# JWT Secret
# Shared between GoTrue (signs tokens) and PostgREST (verifies tokens).
# MUST be the same value for both services.
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_32_char_minimum_random_string

# After setting JWT_SECRET, run: node generate-keys.js "$JWT_SECRET"
# Then paste the output below:
ANON_KEY=PASTE_GENERATED_ANON_KEY_HERE
SERVICE_ROLE_KEY=PASTE_GENERATED_SERVICE_ROLE_KEY_HERE

# -----------------------------------------------------------------------------
# Site URLs
# SITE_URL: primary app URL (used for CORS + GoTrue redirect validation)
# ALLOWED_ORIGINS: comma-separated list of all allowed origins
# -----------------------------------------------------------------------------
SITE_URL=https://cost-tracker.netlify.app
ALLOWED_ORIGINS=https://cost-tracker.netlify.app,https://esticomms.netlify.app

# -----------------------------------------------------------------------------
# SMTP (optional — only needed for password reset emails)
# Leave blank to disable email entirely. Users won't get reset emails.
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Tusco ES
