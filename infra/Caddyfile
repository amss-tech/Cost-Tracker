# =============================================================================
# Tusco ES — Caddy Reverse Proxy
#
# Copy to /etc/caddy/Caddyfile on the droplet and run: systemctl reload caddy
# OR mount into the caddy container (handled by docker-compose.yml).
#
# Caddy automatically provisions and renews Let's Encrypt SSL certificates.
# The domain must already point to this droplet via an A record.
#
# Path routing:
#   /rest/v1/*  → PostgREST (handles supabase.from() calls)
#   /auth/v1/*  → GoTrue    (handles supabase.auth.* calls)
#
# handle_path strips the prefix before forwarding, so:
#   /rest/v1/jobs   → PostgREST receives: /jobs
#   /auth/v1/token  → GoTrue receives:    /token
# =============================================================================

{env.DOMAIN} {

    # -------------------------------------------------------------------------
    # Database REST API — PostgREST
    # -------------------------------------------------------------------------
    handle_path /rest/v1/* {
        reverse_proxy rest:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # -------------------------------------------------------------------------
    # Auth API — GoTrue
    # -------------------------------------------------------------------------
    handle_path /auth/v1/* {
        reverse_proxy auth:9999 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # -------------------------------------------------------------------------
    # Everything else → 404
    # -------------------------------------------------------------------------
    handle {
        respond "Not found" 404
    }

    # Access log (optional — remove if disk space is a concern)
    log {
        output file /var/log/caddy/access.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
